{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stash",
  "version": "0.1.5",
  "identifier": "com.adi.stash",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Stash",
        "width": 920,
        "height": 680,
        "minWidth": 680,
        "minHeight": 480,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/isobutane101/stash/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4NzI2MTRFQkRCRDNGMzMKUldRelA3MjlUbUZ5V0hYeGNLbEVwblFBQnB2Y2ZYNWZNWTlCbXlZeW1hZUVLeVYzSHhVSDVlTi8K"
    }
  }
}
